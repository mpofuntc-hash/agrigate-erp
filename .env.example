PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── OAuth Providers (set in Convex dashboard, not .env.local) ────────────────
# AUTH_GOOGLE_ID=        # Google Cloud Console → OAuth 2.0 Client ID
# AUTH_GOOGLE_SECRET=    # Google Cloud Console → Client Secret
# AUTH_APPLE_ID=         # Apple Developer → Services ID
# AUTH_APPLE_SECRET=     # Apple Developer → Private Key (.p8 contents)
# AUTH_MICROSOFT_ID=     # Azure AD → App Registration → Application (client) ID
# AUTH_MICROSOFT_SECRET= # Azure AD → Certificates & Secrets → Client secret value
# JWT_PRIVATE_KEY=       # openssl genrsa -out private.pem 2048 → paste contents
# JWKS=                  # Derived from JWT_PRIVATE_KEY via @convex-dev/auth CLI

# ── Multi-tenant / AgriGate Platform (set in Convex dashboard) ───────────────
# OPENWEATHER_API_KEY=   # OpenWeatherMap standard plan API key (weather cron)
# WHATSAPP_WEBHOOK_URL=  # Generic webhook URL for payroll WhatsApp notifications
# CAMERA_SECRET=         # Shared secret header for CCTV camera-alert webhook (Titan tier)
